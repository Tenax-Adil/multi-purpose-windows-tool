    "@tailwindcss/vite": "^4.2.4",
    "archiver": "^7.0.1",
    "chokidar": "^5.0.0",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "jimp": "^0.22.12",
    "lucide-react": "^1.14.0",
    "marked": "^18.0.3",
    "multer": "^2.1.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "systeminformation": "^5.31.5",
    "tailwindcss": "^4.2.4",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
